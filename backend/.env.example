# 复制本文件为 .env 后填写真实值；不要将 .env 提交到版本库。
# cp .env.example .env   （Windows 可复制文件并重命名）

# --- 数据库（必填：仅支持 PostgreSQL）---
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME?sslmode=prefer
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@localhost:5432/toolbox

# --- CORS（JSON 数组字符串；与前端实际访问来源一致）---
# BACKEND_CORS_ORIGINS=["http://127.0.0.1:3000","http://localhost:3000"]

# --- JWT ---
SECRET_KEY=change-me-in-production-use-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- 首个超级管理员（库中尚无任何 is_superuser 时可选；生产勿依赖弱密码）---
# FIRST_SUPERUSER=admin@example.com
# FIRST_SUPERUSER_PASSWORD=
# FIRST_SUPERUSER_USERNAME=

# --- 可选：调试与运维 ---
# 打印 SQL：1/true/yes 开启（仅排障）
# SQL_ECHO=0
# 便携包/开发：向数据库写入演示账号（生产务必保持关闭或未设置）
# TOOLBOX_BOOTSTRAP_USERS=0

# --- 可选：MOS 工具适配 ---
# MOS_TOKEN_POOL_USE_DB=1

# --- 便携可执行文件 / 生产部署（一般仅打包脚本或运维注入，本地开发可不配）---
# TOOLBOX_HOST=0.0.0.0
# TOOLBOX_PORT=3000
# TOOLBOX_WORKERS=2
# SQLALCHEMY_POOL_SIZE=4
# SQLALCHEMY_MAX_OVERFLOW=2
# TOOLBOX_FRONTEND_DIST=
# TOOLBOX_STATIC_DIR=
# TOOLBOX_LOG_DIR=
